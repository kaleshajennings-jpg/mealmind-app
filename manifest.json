<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="%PUBLIC_URL%/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
    <meta name="theme-color" content="#FF6B35" />
    <meta name="description" content="MealMind – Your personal AI-powered family meal planner. Plan your week, generate grocery lists, and watch how to cook every meal." />

    <!-- Open Graph / Social Preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="MealMind – Family Meal Planner" />
    <meta property="og:description" content="Plan your family's meals for the week in seconds. Grocery lists included. Watch how to cook every dish on YouTube." />
    <meta property="og:image" content="%PUBLIC_URL%/og-image.png" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="%PUBLIC_URL%/manifest.json" />
    <link rel="apple-touch-icon" href="%PUBLIC_URL%/logo192.png" />

    <!-- Google Fonts preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>MealMind – Family Meal Planner</title>

    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #FFF8F0;
        font-family: 'Nunito', sans-serif;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }
      #root { min-height: 100vh; }
    </style>
  </head>
  <body>
    <noscript>You need to enable JavaScript to run MealMind.</noscript>
    <div id="root"></div>
  </body>
</html>
